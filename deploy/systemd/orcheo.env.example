# Orcheo systemd environment template.
#
# Copy this file to /etc/orcheo/orcheo.env and adjust the credentials, host,
# and auth settings for the target machine.

# Core service ports and URLs.
ORCHEO_HOST=0.0.0.0
ORCHEO_PORT=8000
REDIS_URL=redis://localhost:6379/0

# Shared PostgreSQL connection used by the backend and workspace repository.
ORCHEO_POSTGRES_USER=orcheo
ORCHEO_POSTGRES_PASSWORD=change-me
ORCHEO_POSTGRES_DB=orcheo
ORCHEO_POSTGRES_DSN=postgresql://orcheo:change-me@localhost:5432/orcheo

# Production defaults for the persisted stores.
ORCHEO_CHECKPOINT_BACKEND=postgres
ORCHEO_GRAPH_STORE_BACKEND=postgres
ORCHEO_REPOSITORY_BACKEND=postgres
ORCHEO_CHATKIT_BACKEND=postgres
ORCHEO_VAULT_BACKEND=postgres
ORCHEO_AUTH_SERVICE_TOKEN_BACKEND=postgres

# Multi-workspace deployment defaults.
ORCHEO_MULTI_WORKSPACE_ENABLED=false
ORCHEO_MULTI_WORKSPACE_DEFAULT_WORKSPACE_SLUG=default
ORCHEO_MULTI_WORKSPACE_WORKSPACE_HEADER=X-Orcheo-Workspace
ORCHEO_WORKSPACE_BACKEND=postgres

# Secrets required by the postgres-backed vault.
ORCHEO_VAULT_ENCRYPTION_KEY=replace-with-64-hex-chars

# Browser-facing defaults used by the backend and Canvas.
ORCHEO_CHATKIT_PUBLIC_BASE_URL=http://localhost:5173
ORCHEO_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
